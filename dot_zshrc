# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

##### ENVIRONMENT #####

export EDITOR=nvim
export VISUAL=nvim
export GPG_TTY=$(tty)

# Set up homebrew's paths again, because macOS path_helper messes with $PATH after
# ~/.zshenv is sourced.
[[ -x /opt/homebrew/bin/brew ]] && eval $(/opt/homebrew/bin/brew shellenv)
# Prepend custom path again.
typeset -U path
path=("$HOME/.local/bin" "$HOME/.cargo/bin" $path)

# Use osc52.sh as pbcopy if in a remote session.
if [[ -n "$SSH_TTY" ]]; then
  alias pbcopy='osc52.sh'
fi

##### FUNCTIONS AND COMPLETIONS (before Antidote) #####

fpath=($HOME/.config/zsh/functions $HOME/.config/zsh/completions $fpath)
autoload -Uz y

##### ANTIDOTE ######

# fzf-tab
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:*' fzf-flags --color=fg:1,fg+:2 --bind=tab:accept
zstyle ':fzf-tab:*' switch-group '<' '>'

source ~/.antidote/antidote.zsh
antidote load

##### ZLE AND KEYBINDS #####

# Use the emacs keymap for compatibility
bindkey -e

# Press 'C-x C-e' to edit buffer
autoload edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line

# Press 'C-x y' to copy buffer to clipboard
copy-buffer-to-clipboard() { pbcopy <<< $BUFFER }
zle -N copy-buffer-to-clipboard
bindkey '^Xy' copy-buffer-to-clipboard

##### MISC PLUGINS (after Antidote) #####

# fzf
if [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]]; then
  source /usr/share/doc/fzf/examples/key-bindings.zsh
  source /usr/share/doc/fzf/examples/completion.zsh
fi

eval "$(zoxide init zsh)"
source <(fzf --zsh)

##### CUSTOM ALIASES #####

[[ -f ~/.aliases ]] && source ~/.aliases

##### POWERLEVEL10K #####

[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
